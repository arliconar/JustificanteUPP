<Window
    x:Class="JustificantesUPP.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Envío de Justificantes - UPP">

    <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
       
        <Button x:ConnectionId='2' x:Name="BtnEnviar" 
                Content="Enviar Justificante" 
                                        
                HorizontalAlignment="Stretch" 
                Style="{StaticResource AccentButtonStyle}"/>

        <ProgressRing x:ConnectionId='3' x:Name="Progreso" IsActive="False" HorizontalAlignment="Center"/>

        <TextBlock x:ConnectionId='4' x:Name="StatusText" Foreground="Gray" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>

