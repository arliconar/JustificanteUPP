# ==============================================================================
# .gitignore for C# and WinUI 3 (Windows App SDK)
# ==============================================================================

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# Visual Studio cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
bld/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Build results on 'Bin' / 'Obj' directories
**/[Bb]in/*
**/[Oo]bj/*

# Visual Studio auto generated files
Generated\ Files/
Generated Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.VisualState.xml
TestResult.xml

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/
.artifacts/

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.idb
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
!Directory.Build.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# ReSharper / JetBrains
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Click-Once directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml

# ==============================================================================
# WinUI 3 / Windows App SDK / UWP Specific Exclusions
# ==============================================================================

# App packaging exclusions
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.msix
*.msixbundle
*.appxupload
*.msixupload

# Temporary key files for packaging
*_TemporaryKey.pfx

# Nuget packages
*.nupkg
*.snupkg

# SQLite databases (generated during local testing/debugging)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
